@page "/"
@using System.Text.Json
@using System.IO
@using FileTransfer

<style>
    /* 1. 謎のスクロールバー(二重スクロール)を完全に除去 */
    :global(html), :global(body) {
        margin: 0;
        padding: 0;
        overflow: hidden !important; /* 全体のスクロールを禁止 */
        height: 100%;
    }

    .main-wrapper {
        position: relative;
        height: 100vh;
        display: flex;
        flex-direction: column;
        background-color: #f8f9fa;
    }

    /* 2. リストエリア：ここだけがスクロールする */
    .table-scroll-area {
        flex: 1;
        overflow: auto; /* 縦横必要に応じてスクロール */
        padding: 10px;
        padding-bottom: 75px; /* ログエリアとの重なり防止 */
    }

    /* 3. ログレイヤー：2行分固定で、内部スクロール可能に */
    .fixed-log-layer {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        height: 60px; /* 2行分の高さに固定 */
        background-color: #1e1e1e;
        color: #4af626; /* 視認性の良いグリーン */
        border-top: 2px solid #333;
        z-index: 2000;
        padding: 5px 15px;
        box-shadow: 0 -5px 15px rgba(0,0,0,0.5);
        overflow-y: auto; /* 過去をさかのぼれるように */
    }

    /* ログの各行スタイル */
    .log-line {
        font-family: 'Consolas', monospace;
        font-size: 0.82rem;
        line-height: 1.4;
        white-space: nowrap;
        border-bottom: 1px solid #333;
    }

    .checkbox-center {
        display: block;
        margin: 0 auto;
        width: 1.1rem;
        height: 1.1rem;
        cursor: pointer;
    }
</style>

<div class="main-wrapper">
    <div class="p-2 bg-white border-bottom shadow-sm flex-shrink-0">
        <div class="d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-2">
                <span class="fw-bold small">スロット:</span>
                <div class="btn-group btn-group-sm">
                    @for (int i = 1; i <= 3; i++)
                    {
                        var slot = i;
                        <button type="button" class="btn @(currentSlot == slot ? "btn-primary" : "btn-outline-primary")" 
                                @onclick="() => ChangeSlot(slot)">@slot</button>
                    }
                </div>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-success px-3 fw-bold" @onclick="RunAll">すべて実行</button>
                <button class="btn btn-sm btn-primary" @onclick="SaveSettings">保存</button>
                <button class="btn btn-sm btn-secondary" @onclick="AddItem">行追加</button>
            </div>
        </div>
    </div>

    <div class="table-scroll-area">
        <table class="table table-sm table-hover align-middle bg-white border shadow-sm">
            <thead class="table-light small text-center sticky-top" style="top: -11px; z-index: 10;">
                <tr>
                    <th>転送元パス</th>
                    <th style="width: 70px;">元削除</th>
                    <th>転送先パス</th>
                    <th style="width: 100px;">フォルダごと</th>
                    <th style="width: 90px;">日付付与</th>
                    <th style="width: 80px;">状態</th>
                    <th style="width: 100px;">操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in settings.Items)
                {
                    <tr>
                        <td class="p-0"><input type="text" class="form-control form-control-sm border-0 bg-transparent px-2" @bind="item.SourcePath" placeholder="C:\Source"></td>
                        <td><input type="checkbox" @bind="item.DeleteAfterTransfer" class="checkbox-center"></td>
                        <td class="p-0"><input type="text" class="form-control form-control-sm border-0 bg-transparent px-2" @bind="item.DestPath" placeholder="D:\Destination"></td>
                        <td><input type="checkbox" @bind="item.TransferEntireFolder" class="checkbox-center"></td>
                        <td><input type="checkbox" @bind="item.UseTimestamp" class="checkbox-center"></td>
                        <td class="text-center">
                            <span class="badge @(item.Status == "完了" ? "bg-success" : item.Status == "エラー" ? "bg-danger" : "bg-secondary")" style="font-size: 0.7rem;">@item.Status</span>
                        </td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center gap-2">
                                <button class="btn btn-link btn-sm text-primary p-0" @onclick="() => RunSingle(item)">実行</button>
                                <button class="btn btn-link btn-sm text-danger p-0" @onclick="() => settings.Items.Remove(item)">削除</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="fixed-log-layer">
        @if (!logs.Any()) { <div class="text-muted small mt-1">// 準備完了</div> }
        @* 最新を一番上に表示 (さかのぼりやすくするため) *@
        @foreach (var log in logs.AsEnumerable().Reverse())
        {
            <div class="log-line text-truncate" title="@log">
                <span style="color: #888; font-size: 0.75rem;">▶</span> @log
            </div>
        }
    </div>
</div>

@code {
    private TransferSettings settings = new();
    private int currentSlot = 1;
    private List<string> logs = new();
    private FileTransferService transferService = new();

    protected override void OnInitialized() => LoadSettings(1);
    private void AddItem() => settings.Items.Add(new TransferItem());

    private async Task ChangeSlot(int slot)
    {
        SaveSettings();
        currentSlot = slot;
        LoadSettings(slot);
        AddLog($"スロット {slot} 読込");
    }

    private void SaveSettings()
    {
        try {
            File.WriteAllText($"settings_{currentSlot}.json", JsonSerializer.Serialize(settings, new JsonSerializerOptions { WriteIndented = true }));
            AddLog($"設定 {currentSlot} 保存");
        } catch (Exception ex) { AddLog($"保存エラー: {ex.Message}"); }
    }

    private void LoadSettings(int slot)
    {
        string path = $"settings_{slot}.json";
        settings = File.Exists(path) ? JsonSerializer.Deserialize<TransferSettings>(File.ReadAllText(path)) ?? new() : new();
        StateHasChanged();
    }

    private async Task RunSingle(TransferItem item)
    {
        item.Status = "実行中";
        StateHasChanged();
        await transferService.ExecuteTransfer(item, (msg) => { AddLog(msg); StateHasChanged(); });
        StateHasChanged();
    }

    private async Task RunAll()
    {
        if (!settings.Items.Any()) return;
        var targets = settings.Items.ToList();
        foreach (var item in targets) await RunSingle(item);
        AddLog("完了");
    }

    private void AddLog(string msg)
    {
        logs.Add($"[{DateTime.Now:HH:mm:ss}] {msg}");
        if (logs.Count > 100) logs.RemoveAt(0); // 100件まで保持
    }
}